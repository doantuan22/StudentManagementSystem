<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="student-management-jpa" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.qlsv.model.RoleEntity</class>
        <class>com.qlsv.model.User</class>
        <class>com.qlsv.model.Faculty</class>
        <class>com.qlsv.model.Room</class>
        <class>com.qlsv.model.ClassRoom</class>
        <class>com.qlsv.model.Subject</class>
        <class>com.qlsv.model.Lecturer</class>
        <class>com.qlsv.model.Student</class>
        <class>com.qlsv.model.CourseSection</class>
        <class>com.qlsv.model.Schedule</class>
        <class>com.qlsv.model.Enrollment</class>
        <class>com.qlsv.model.Score</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>
        <properties>
            <property name="hibernate.hbm2ddl.auto" value="none"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.highlight_sql" value="false"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
        </properties>
    </persistence-unit>
</persistence>
